{
  "name": "pi-threading",
  "version": "0.5.1",
  "description": "Cross-thread communication extension for pi coding agent — independent threads that coordinate work, share state, and converse without losing context",
  "keywords": [
    "pi-package",
    "pi-extension",
    "threads",
    "multi-agent"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OFRBG/pi-threading.git"
  },
  "files": [
    "index.ts",
    "src",
    "bin",
    "examples",
    "THREAD-MODEL.md"
  ],
  "type": "module",
  "bin": {
    "pi-threading": "./bin/thread-cli.mjs"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "scripts": {
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "node --import tsx --test test/unit.test.ts",
    "test:e2e": "node --import tsx --test test/e2e.test.ts",
    "live": "bash live.sh",
    "lint": "eslint src test index.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.3",
    "@eslint/js": "^9.0.0",
    "@types/node": "^26.1.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.5.0",
    "tsx": "^4.0.0",
    "typescript-eslint": "^8.0.0"
  },
  "volta": {
    "node": "26.4.0"
  }
}
